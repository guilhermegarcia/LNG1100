# Ignore everything by default
*

# Allow Git to see the diapos directory and subdirectories
!diapos/
!diapos/**/

# Include only specific PDF files in diapos subdirectories
!diapos/**/LNG*.pdf

# Explicitly ignore everything else in diapos
diapos/*

# Include specific other directories
!scripts/
!projets/
!donnees/
!solutions/
!solutions/**

# Always include specific files
!README.md
!project.Rproj

# Ignore system and temporary files
.DS_Store
.Rproj.user
makefile
